            android:keyWidth="15%p"
            android:keyEdgeFlags="right"
            android:keyIcon="@drawable/ic_backspace" />
    </Row>

    <Row android:rowEdgeFlags="bottom">
        <Key
            android:codes="-2"
            android:keyWidth="12%p"
            android:keyEdgeFlags="left"
            android:keyLabel="@string/keyboard_label_letters" />
        <Key
            android:codes="-10001"
            android:keyWidth="10%p"
            android:keyIcon="@drawable/ic_emoji" />
        <Key
            android:codes="-10002"
            android:keyWidth="10%p"
            android:keyIcon="@drawable/ic_language" />
        <Key
            android:codes="32"
            android:isRepeatable="true"
            android:keyWidth="46%p"
            android:keyLabel="@string/keyboard_label_space" />
        <Key
            android:codes="46"
            android:keyWidth="10%p"
            android:keyLabel="@string/keyboard_label_period" />
        <Key
            android:codes="10"
            android:keyWidth="12%p"
            android:keyEdgeFlags="right"
            android:keyIcon="@drawable/ic_enter" />
    </Row>
