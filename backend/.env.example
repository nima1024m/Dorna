# Dorna backend — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored; this file is not,
# so keep ONLY placeholders here (never real secrets).

# ---- App ----
APP_NAME="Dorna AI Keyboard Backend"
API_BASE_URL="https://api.example.com"
APP_BASE_URL="dorna://openapp"

# ---- Database ----
DB_URL="postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME"

# ---- Auth / JWT ----
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ALGO="HS256"
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=30
PRE_AUTH_TTL_MIN=5
RATE_PRE_AUTH_PER_MIN=10
SIGNUP_TOKEN_TTL_MIN=5
VERIFY_TOKEN_TTL_MIN=5
RATE_SIGNIN_PER_MIN=10
RATE_SIGNUP_PER_MIN=5
RATE_RESEND_ACTIVE_PER_MIN=3
RESET_TTL_MIN=10
GOOGLE_OAUTH_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
APPLE_CLIENT_ID="com.dorna.app"
AVATAR_MAX_MB=5

# ---- LLM provider ----
LLM_AGENT="gemini"

# API key sent to the model provider as the `x-goog-api-key` header.
#  - Direct Gemini:  a Google AI Studio key (AIza...).
#  - Gateway mode:   the claude-gateway API key (must match the gateway's API_KEY).
GEMINI_API_KEY="your-gemini-or-gateway-api-key"

# Route every google-genai call through a claude-gateway instance (which speaks
# the Gemini wire protocol and is backed by Claude) instead of Google's servers.
#   - Leave EMPTY/unset to call Google Gemini directly (default behaviour).
#   - Set to the gateway base URL to use Claude, e.g. http://localhost:8000
# Do NOT include "/v1beta" — the SDK appends the version path itself.
# Note: Gemini "Google Search grounding" (used by the news/topic features) is not
# supported by the gateway. Those flows therefore always bypass the gateway and call
# real Gemini directly (hybrid routing) — set GEMINI_DIRECT_API_KEY below so they can
# authenticate. Grammar/translate/tone/podcast/OCR flows go through the gateway.
GEMINI_BASE_URL=

# Real Google Gemini API key (AIza...) used ONLY by the grounding flows (news/topics)
# that bypass the gateway. Required in gateway mode, since GEMINI_API_KEY above is then
# the gateway key, not a Google key. Leave EMPTY when not using the gateway: the direct
# flows fall back to GEMINI_API_KEY, which is already the real Google key.
GEMINI_DIRECT_API_KEY=

# ---- Model selection (resolved by the gateway's model map when GEMINI_BASE_URL is set) ----
GRAMMAR_MODEL={"seperator":"gemini-2.5-flash-lite", "grammar_fix":"gemini-2.5-flash-lite"}
TRANSLATE_MODEL="gemini-3-flash-preview"
TONE_MODEL="gemini-2.5-flash-lite"
TTS_COVER_MODEL="gemini-3-flash-preview"
TTS_OCR_MODEL="gemini-2.5-flash-lite"
TTS_PROCESS_MODEL="gemini-3-flash-preview"
TTS_VOICE_MODEL="gemini-2.5-pro-tts"
PODCAST_GENERATE_MODEL="gemini-3-flash-preview"
PDOCAST_TTS_MODEL="gemini-2.5-flash-preview-tts"

# ---- Assistant config ----
USER_APPROVED_TONE_LIMIT=2
ASSISTANT_TONES=["formal","friendly","concise","polish"]
ASSISTANT_LANGS=["fa","en"]
CORS_ORIGINS=["*"]
TTS_MAX_UPLOAD_IMAGES=5

# ---- Token pricing (USD per 1k tokens) ----
MODEL_PRICING={"gemini-2.5-flash":{"input":0.00030,"output":0.00250},"gemini-3-flash-preview":{"input":0.00050,"output":0.00300},"gemini-2.5-pro-tts":{"input":0.00100,"output":0.02000}}

# ---- Redis / Celery ----
REDIS_URL="redis://127.0.0.1:6379/0"
CELERY_BROKER_URL="redis://127.0.0.1:6379/0"
CELERY_RESULT_BACKEND="redis://127.0.0.1:6379/0"

# ---- Google Cloud TTS service account ----
# Used by the Text-to-Speech pipeline, which always talks to Google Cloud directly
# (it is NOT routed through the gateway). Paste the service-account fields here.
GOOGLE_APPLICATION_CREDENTIALS_TYPE="service_account"
GOOGLE_APPLICATION_CREDENTIALS_PROJECT_ID="your-gcp-project-id"
GOOGLE_APPLICATION_CREDENTIALS_PRIVATE_KEY_ID="your-private-key-id"
GOOGLE_APPLICATION_CREDENTIALS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_APPLICATION_CREDENTIALS_CLIENT_EMAIL="your-sa@your-gcp-project-id.iam.gserviceaccount.com"
GOOGLE_APPLICATION_CREDENTIALS_CLIENT_ID="your-client-id"
GOOGLE_APPLICATION_CREDENTIALS_AUTH_URI="https://accounts.google.com/o/oauth2/auth"
GOOGLE_APPLICATION_CREDENTIALS_TOKEN_URI="https://oauth2.googleapis.com/token"
GOOGLE_APPLICATION_CREDENTIALS_AUTH_PROVIDER_X509_CERT_URL="https://www.googleapis.com/oauth2/v1/certs"
GOOGLE_APPLICATION_CREDENTIALS_CLIENT_X509_CERT_URL="https://www.googleapis.com/robot/v1/metadata/x509/your-sa%40your-gcp-project-id.iam.gserviceaccount.com"
GOOGLE_APPLICATION_CREDENTIALS_UNIVERSE_DOMAIN="googleapis.com"

# ---- Email (Brevo) ----
BREVO_API_KEY="your-brevo-api-key"
BREVO_DORNA_FORGET_PASS_TEMPLATE_ID=1
BREVO_DORNA_SIGNUP_TEMPLATE_ID=2
